<Window x:Class="WindowsPomodoro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomodoro Timer" Height="300" Width="400"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Timer display -->
        <TextBlock x:Name="TimerDisplay" Grid.Row="0"
                   Text="30:00" FontSize="96" FontWeight="Light"
                   FontFamily="Segoe UI"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Control buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,10,0,10">
            <Button x:Name="StartPauseButton" Content="Start"
                    Width="100" Height="36" Margin="5" FontSize="14"
                    Click="StartPauseButton_Click"/>
            <Button x:Name="ResetButton" Content="Reset"
                    Width="100" Height="36" Margin="5" FontSize="14"
                    Click="ResetButton_Click"/>
        </StackPanel>

        <!-- Debug -->
        <Button x:Name="DebugButton" Content="Set 5s" Grid.Row="2"
                HorizontalAlignment="Right"
                Width="60" Height="24" FontSize="11" Foreground="Gray"
                Click="DebugButton_Click"/>
    </Grid>
</Window>
