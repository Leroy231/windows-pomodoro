<Window x:Class="WindowsPomodoro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomodoro Timer" Height="395" Width="480"
        Icon="icon.ico"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen">
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo>
            <TaskbarItemInfo.ThumbButtonInfos>
                <ThumbButtonInfo x:Name="StartPauseThumbButton"
                                 Description="Start"
                                 Click="StartPauseThumbButton_Click"/>
                <ThumbButtonInfo x:Name="ResetThumbButton"
                                 Description="Reset"
                                 Click="ResetThumbButton_Click"/>
            </TaskbarItemInfo.ThumbButtonInfos>
        </TaskbarItemInfo>
    </Window.TaskbarItemInfo>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Timer display -->
        <TextBlock x:Name="TimerDisplay" Grid.Row="0"
                   Text="30:00" FontSize="96" FontWeight="Light"
                   FontFamily="Segoe UI"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Control buttons -->
        <StackPanel Grid.Row="1" Orientation="Vertical"
                    HorizontalAlignment="Center" Margin="0,10,0,10">
            <WrapPanel HorizontalAlignment="Center">
                <Button x:Name="StartPauseButton" Content="Start"
                        Width="100" Height="36" Margin="5" FontSize="14"
                        Click="StartPauseButton_Click"/>
                <Button x:Name="ResetButton" Content="Reset"
                        Width="100" Height="36" Margin="5" FontSize="14"
                        Click="ResetButton_Click"/>
                <StackPanel x:Name="FrequentTimesPanel" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="6,0,0,0"/>
                <Button x:Name="ManageFrequentTimesButton" Content="+"
                        Width="28" Height="28" Margin="4,5,5,5"
                        FontSize="16" Foreground="Gray"
                        ToolTip="Add or remove frequent times"
                        Click="ManageFrequentTimesButton_Click"/>
            </WrapPanel>

            <Border x:Name="FrequentTimesEditor" Visibility="Collapsed"
                    BorderBrush="#FFD0D0D0" BorderThickness="1"
                    Padding="8" Margin="5,4,5,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Frequent" FontSize="11" Foreground="Gray"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="FrequentMinutesBox" Width="44" Height="24"
                                 FontSize="11" VerticalContentAlignment="Center"
                                 Margin="0,0,4,0" MaxLength="3"/>
                        <TextBlock Text="min" FontSize="11" Foreground="Gray"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button Content="Add" Height="24" FontSize="11"
                                Foreground="Gray" Padding="8,0"
                                Click="AddFrequentMinutes_Click"/>
                    </StackPanel>
                    <WrapPanel x:Name="FrequentTimesListPanel"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <TextBlock x:Name="FrequentTimesError" FontSize="10"
                               Foreground="Firebrick" HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Bottom row -->
        <CheckBox x:Name="AutoStartCheckBox" Content="Start with Windows"
                  Grid.Row="2" HorizontalAlignment="Left"
                  VerticalAlignment="Center" FontSize="11" Foreground="Gray"
                  Checked="AutoStartCheckBox_Changed"
                  Unchecked="AutoStartCheckBox_Changed"/>
        <StackPanel Grid.Row="2" Orientation="Vertical"
                    HorizontalAlignment="Right">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,0,0,4">
                <TextBox x:Name="CustomMinutesBox" Width="40" Height="24"
                         FontSize="11" VerticalContentAlignment="Center"
                         Margin="0,0,4,0" MaxLength="3"/>
                <Button Content="Set min" Height="24" FontSize="11"
                        Foreground="Gray" Padding="4,0"
                        Click="SetCustomMinutes_Click"/>
                <Button x:Name="DebugButton" Content="Set 5s"
                        Margin="8,0,0,0"
                        Width="60" Height="24" FontSize="11" Foreground="Gray"
                        Click="DebugButton_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Break" FontSize="11" Foreground="Gray"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="BreakSecondsBox" Width="48" Height="24"
                         FontSize="11" VerticalContentAlignment="Center"
                         Margin="0,0,4,0" MaxLength="5"/>
                <TextBlock Text="sec" FontSize="11" Foreground="Gray"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <Button Content="Save" Height="24" FontSize="11"
                        Foreground="Gray" Padding="4,0"
                        Click="SaveBreakSeconds_Click"/>
            </StackPanel>
            <TextBlock x:Name="BreakSecondsError" FontSize="10"
                       Foreground="Firebrick" HorizontalAlignment="Right"
                       Margin="0,2,0,0"/>
        </StackPanel>
        <!-- Attribution -->
        <TextBlock Grid.Row="3" HorizontalAlignment="Center" FontSize="9"
                   Foreground="Gray" Margin="0,4,0,0">
            <Hyperlink NavigateUri="https://icons8.com/icon/lPmL0NaypRwo/tomato"
                       RequestNavigate="Hyperlink_RequestNavigate">Tomato</Hyperlink>
            icon by
            <Hyperlink NavigateUri="https://icons8.com"
                       RequestNavigate="Hyperlink_RequestNavigate">Icons8</Hyperlink>
        </TextBlock>
    </Grid>
</Window>
